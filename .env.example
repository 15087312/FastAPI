# FastAPI Mall 环境变量配置模板
# 复制此文件为 .env 并根据实际情况修改配置
# 注意：标记 * 的为必填项，不能为空

# ==================== 数据库配置 ====================
POSTGRES_USER=postgres          # * 数据库用户名
POSTGRES_PASSWORD=MyStr0ngP@ssw0rd!2024  # * 数据库密码（至少 12 位，包含大小写字母、数字、特殊字符）
POSTGRES_HOST=localhost         # * 数据库主机（Docker 环境使用 'db'）
POSTGRES_PORT=5432              # 数据库端口（默认 5432）
POSTGRES_DB=mydb                # * 数据库名称

# ==================== Redis 配置 ====================
REDIS_HOST=localhost            # * Redis 主机（Docker 环境使用 'redis'）
REDIS_PORT=6379                 # * Redis 端口（默认 6379）
REDIS_DB=0                      # Redis 数据库编号（默认 0）
REDIS_PASSWORD=MyRedisP@ss88   # Redis 密码（可选，至少 8 位）
REDIS_POOL_SIZE=50              # Redis 连接池大小
REDIS_POOL_MAX_OVERFLOW=100     # Redis 最大溢出连接数
REDIS_SOCKET_TIMEOUT=5.0        # Socket 超时时间（秒）
REDIS_SOCKET_CONNECT_TIMEOUT=2.0  # 连接超时时间（秒）

# ==================== Kafka 配置 ====================
KAFKA_ENABLED=false             # 是否启用 Kafka（true/false）
KAFKA_BOOTSTRAP_SERVERS=localhost:9092  # Kafka 服务器地址
KAFKA_CONSUMER_GROUP=inventory-consumer-group  # Kafka 消费者组
KAFKA_TOPIC=inventory-changes   # 库存变更主题
KAFKA_MAX_MESSAGES_PER_SECOND=100  # 每秒最大处理消息数
KAFKA_BATCH_SIZE=10             # 批量处理大小

# 多实例 Redis 配置（可选，用于 Redlock）
# REDIS_HOSTS=redis1.example.com,redis2.example.com,redis3.example.com

# ==================== 应用配置 ====================
HOST=0.0.0.0                    # 服务器监听地址
PORT=8000                       # 服务器端口
DEBUG=False                     # 调试模式（开发：True，生产：False）

# ==================== pgAdmin 配置 ====================
PGADMIN_EMAIL=admin@example.com # pgAdmin 登录邮箱
PGADMIN_PASSWORD=Adm1nP@ssw0rd! # pgAdmin 登录密码（至少 8 位）

# ==================== 并发配置 ====================
# Uvicorn Workers 数量（可选）
# 默认根据 CPU 核心数自动计算：CPU * 2 + 1
# 开发环境建议：1-2
# 生产环境建议：4-8（根据 CPU 核心数调整）
# UVICORN_WORKERS=4

# 每个 Worker 的最大连接数（可选）
# WEB_CONCURRENCY=1000

# ==================== 数据库连接池配置 ====================
# 连接池大小（默认 10，建议根据 worker 数量调整）
# 公式：每个 worker 分配的连接数 = DB_POOL_SIZE / workers
DB_POOL_SIZE=10

# 最大溢出连接数（默认 20，建议：pool_size × 2）
DB_MAX_OVERFLOW=20

# ==================== Celery 配置 ====================
# Celery 使用上面的 Redis 配置作为 broker 和 backend

# ==================== 日志配置 ====================
LOG_LEVEL=INFO                  # 日志级别：DEBUG, INFO, WARNING, ERROR, CRITICAL

# ==================== 通用模型配置 ====================
# 启用的模型列表（逗号分隔）
ENABLED_MODELS=Product,ProductStock,InventoryReservation,InventoryLog,IdempotencyKey,Warehouse,Order

# 是否使用内置的库存模型（True/False）
USE_BUILTIN_INVENTORY_MODELS=True

# 是否使用自定义模型（True/False）
USE_CUSTOM_MODELS=False

# 自定义模型配置文件路径（JSON 格式）
CUSTOM_MODEL_CONFIG_PATH=app/core/model_configs.json

# 业务逻辑配置
INVENTORY_OPERATION_TYPES=increase,decrease,freeze,unfreeze,reserve,confirm,release
ENABLE_KAFKA_SYNC=false
ENABLE_REDIS_CACHE=true
ENABLE_BLOOM_FILTER=true
ENABLE_IDEMPOTENCY=true

# 性能配置
REDIS_CACHE_TTL=0               # Redis 缓存过期时间（秒），0 表示永不过期
BATCH_OPERATION_MAX_SIZE=100    # 批量操作最大数量
PRE_REGISTER_LUA_SCRIPTS=true   # 是否启用 Lua 脚本预注册

# 日志配置
LOG_OPERATIONS=true             # 是否记录详细的操作日志

# ==================== 生产环境配置示例 ====================
# POSTGRES_HOST=prod-db.example.com
# POSTGRES_PORT=5432
# POSTGRES_DB=production_db
# REDIS_HOST=prod-redis.example.com
# REDIS_PORT=6379