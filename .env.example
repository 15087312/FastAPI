# FastAPI Mall 环境变量配置模板
# 复制此文件为 .env 并根据实际情况修改配置
# 注意：标记 * 的为必填项，不能为空

# ==================== 数据库配置 ====================
POSTGRES_USER=postgres          # * 数据库用户名
POSTGRES_PASSWORD=MyStr0ngP@ssw0rd!2024  # * 数据库密码（至少 12 位，包含大小写字母、数字、特殊字符）
POSTGRES_HOST=localhost         # * 数据库主机（Docker 环境使用 'db'）
POSTGRES_PORT=5432              # 数据库端口（默认 5432）
POSTGRES_DB=mydb                # * 数据库名称

# ==================== Redis 配置 ====================
REDIS_HOST=localhost            # * Redis 主机（Docker 环境使用 'redis'）
REDIS_PORT=6379                 # * Redis 端口（默认 6379）
REDIS_DB=0                      # Redis 数据库编号（默认 0）
REDIS_PASSWORD=MyRedisP@ss88    # Redis 密码（可选，至少 8 位）
REDIS_PASSWORD=MyRedisP@ss88    # Redis 密码（可选，至少 8 位）

# 多实例 Redis 配置（可选，用于 Redlock）
# REDIS_HOSTS=redis1.example.com,redis2.example.com,redis3.example.com

# ==================== 应用配置 ====================
HOST=0.0.0.0                    # 服务器监听地址
PORT=8000                       # 服务器端口
DEBUG=False                     # 调试模式（开发：True，生产：False）

# ==================== pgAdmin 配置 ====================
PGADMIN_EMAIL=admin@example.com # pgAdmin 登录邮箱
PGADMIN_PASSWORD=Adm1nP@ssw0rd! # pgAdmin 登录密码（至少 8 位）

# ==================== 并发配置 ====================
# Uvicorn Workers 数量（可选）
# 默认根据 CPU 核心数自动计算：CPU * 2 + 1
# 开发环境建议：1-2
# 生产环境建议：4-8（根据 CPU 核心数调整）
# UVICORN_WORKERS=4

# 每个 Worker 的最大连接数（可选）
# WEB_CONCURRENCY=1000

# ==================== 数据库连接池配置 ====================
# 连接池大小（默认 10，建议根据 worker 数量调整）
# 公式：每个 worker 分配的连接数 = DB_POOL_SIZE / workers
DB_POOL_SIZE=10

# 最大溢出连接数（默认 20，建议：pool_size × 2）
DB_MAX_OVERFLOW=20

# ==================== Celery 配置 ====================
# Celery 使用上面的 Redis 配置作为 broker 和 backend

# ==================== 日志配置 ====================
LOG_LEVEL=INFO                  # 日志级别：DEBUG, INFO, WARNING, ERROR, CRITICAL

# ==================== 生产环境配置示例 ====================
# POSTGRES_HOST=prod-db.example.com
# POSTGRES_PORT=5432
# POSTGRES_DB=production_db
# REDIS_HOST=prod-redis.example.com
# REDIS_PORT=6379