# FastAPI Mall 环境变量配置
# 用于本地开发和测试环境
# 复制自 .env.example，根据实际环境修改

# ==================== 数据库配置 ====================
POSTGRES_USER=postgres          # 数据库用户名
POSTGRES_PASSWORD=123456        # 数据库密码（生产环境请修改为强密码）
POSTGRES_HOST=localhost         # 数据库主机（本地：localhost，Docker：db）
POSTGRES_PORT=5432              # 数据库端口
POSTGRES_DB=mydb                # 数据库名称

# ==================== 数据库连接池配置 ====================
DB_POOL_SIZE=50                 # 数据库连接池大小（增大以支持多worker）
DB_MAX_OVERFLOW=100            # 最大溢出连接数

# ==================== Redis 配置 ====================
REDIS_HOST=localhost            # Redis 主机（本地：localhost，Docker：redis）
REDIS_PORT=6379                 # Redis 端口
REDIS_DB=0                      # Redis 数据库编号
REDIS_POOL_SIZE=50              # Redis 连接池大小
REDIS_POOL_MAX_OVERFLOW=50      # Redis 最大溢出连接数（限制最大连接总数）
REDIS_SOCKET_TIMEOUT=5.0        # Socket 超时时间（秒），避免过短导致等待
REDIS_SOCKET_CONNECT_TIMEOUT=2.0  # 连接超时时间（秒）

# ==================== 应用配置 ====================
HOST=0.0.0.0                    # 服务器监听地址
PORT=8000                       # 服务器端口
DEBUG=False                     # 调试模式（开发：True，生产：False）

# ==================== 日志配置 ====================
LOG_LEVEL=INFO                  # 日志级别：DEBUG, INFO, WARNING, ERROR, CRITICAL
